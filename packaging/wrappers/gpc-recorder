#!/bin/bash
# Wrapper: GPC sequence recorder web UI
set -euo pipefail
GPC_ROOT=/opt/gpc-recorder/repo
TOOL_DIR="$GPC_ROOT/tools/gpc_sequence_recorder"
DATA_DIR="${GPC_RECORDER_DATA:-${XDG_CACHE_HOME:-$HOME/.cache}/gpc-recorder}"
VENV="${DATA_DIR}/venv"
export GPC_RECORDER_DATA="$DATA_DIR"
export PYTHONPATH="$TOOL_DIR"

# shellcheck source=/opt/gpc-recorder/seed-exports.sh
source /opt/gpc-recorder/seed-exports.sh
gpc_require_writable_data_dir "$DATA_DIR"
gpc_seed_exports "$DATA_DIR"

if [[ ! -x "$VENV/bin/python" ]]; then
  python3 -m venv "$VENV"
  "$VENV/bin/pip" install -q --upgrade pip
  "$VENV/bin/pip" install -q -r "$TOOL_DIR/requirements.txt"
fi

exec "$VENV/bin/python" -m gpc_recorder "$@"
